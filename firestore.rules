rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "prashantsrivastava761@gmail.com";
    }

    function isValidSearch(data) {
      return data.userId is string &&
             data.type in ['text', 'image'] &&
             data.medicineName is string && data.medicineName.size() < 500 &&
             data.alternativesCount is number &&
             data.fullResult is map &&
             data.createdAt == request.time;
    }

    match /searches/{searchId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidSearch(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
